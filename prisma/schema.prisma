generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  phone     String?
  role      String   @default("CLIENT") // "ADMIN" ou "CLIENT"
  plan      String   @default("NONE") // "NONE", "STANDARD", "VIP", "VIP_PREMIUM", "VIP_ENTERPRISE"
  status    String   @default("ACTIVE") // "ACTIVE", "INACTIVE", "SUSPENDED"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Article {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String
  content   String
  imageUrl  String
  category  String
  date      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  company   String?
  phone     String?
  email     String
  subject   String?
  message   String
  createdAt DateTime @default(now())
}
